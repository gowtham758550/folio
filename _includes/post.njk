---
layout: base.njk
---
<article class="section post-article">
  <div class="section-heading">
    <p class="section-tag">{{ page.date | readableDate }}</p>
    <h1>{{ title }}</h1>
    {% if description %}
    <p class="hero-text">{{ description }}</p>
    {% endif %}
  </div>
  <div class="post-body">
    {{ content | safe }}
  </div>
  <a class="button button-secondary post-back" href="/blog/">← All posts</a>
</article>
